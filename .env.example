# Copy this file to .env and fill in your values
# These are set as environment variables in Railway dashboard

SUPABASE_URL=https://your-project-ref.supabase.co
# Server + scripts use the service-role key (bypasses RLS). Required.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Anon key is still used for client auth and server-side JWT verification.
SUPABASE_ANON_KEY=your-anon-key-here

# Airtable token. Railway provides this as AIRTABLE_API_KEY; AIRTABLE_PAT is
# accepted as a legacy fallback.
AIRTABLE_API_KEY=your-airtable-token-here

NODE_ENV=production
PORT=5000

# ── Auth (dark by default; leave unset to keep auth OFF) ─────────────────────
# Server gate. Set to "true" only after Supabase Auth is live, users exist, and
# public.user_roles is seeded. When unset/anything-else, the gate is a no-op.
AUTH_ENABLED=false
# Optional shared secret for machine-to-machine /api/sync/* callers.
# SYNC_SECRET=your-sync-secret-here

# ── Client (VITE_*) build-time vars ──────────────────────────────────────────
# Client auth gate. "true" shows the login screen; unset keeps the portal open.
VITE_AUTH_ENABLED=false
# Required by the client only when VITE_AUTH_ENABLED=true (anon key is correct here).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: set only if the API is on a different origin than the frontend.
# VITE_API_URL=https://api.example.com
